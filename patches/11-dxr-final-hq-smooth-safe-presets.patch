diff --git a/src/opengl/gl_d3d12raylight.cpp b/src/opengl/gl_d3d12raylight.cpp
index 7ca8dfa..7a6bcbc 100644
--- a/src/opengl/gl_d3d12raylight.cpp
+++ b/src/opengl/gl_d3d12raylight.cpp
@@ -2381,24 +2381,31 @@ void StoreRaytracedOutput(uint2 dispatchPixel, float4 color)
     x1 = min(max(x1, x0 + 1u), screenW);
     y1 = min(max(y1, y0 + 1u), screenH);
 
-    // Playable TDR-safe composite:
-    // The old low-resolution path wrote one full shaded color to each output block.
-    // That was stable, but visibly pixelated the entire image into large squares.
-    // For full lighting mode, preserve full-resolution raster texture detail and only
-    // reuse the low-resolution RT lighting multiplier. This keeps RT shadows/light
-    // cheap while avoiding chunky texture blocks. Diagnostic modes keep their raw
-    // colors so tests remain easy to identify.
+    // DXR FINAL HQ SMOOTH composite:
+    // Keep the stable low-resolution full-lighting pass, but do not write its
+    // shaded color as a hard rectangular block.  Treat the RT result as a
+    // controlled lighting multiplier for the full-resolution raster image, fade
+    // it toward the original image at block borders, and use mostly luminance
+    // instead of raw low-res chroma. This keeps contact shadows / RT lighting
+    // visible while hiding the large pixel-square grid.
     if (gRaygenMode == 4u)
     {
         uint sx = ((dispatchPixel.x * 2u + 1u) * screenW) / (dispatchW * 2u);
         uint sy = ((dispatchPixel.y * 2u + 1u) * screenH) / (dispatchH * 2u);
         uint2 samplePixel = uint2(min(sx, screenW - 1u), min(sy, screenH - 1u));
+
+        const float3 luma = float3(0.299, 0.587, 0.114);
         float3 sampleBase = max(gAlbedoTex.Load(int3(samplePixel, 0)).rgb, float3(0.08, 0.08, 0.08));
-        float3 lightRatio = color.rgb / sampleBase;
+        float3 rawRatio = color.rgb / sampleBase;
+
+        float baseLum = max(dot(sampleBase, luma), 0.08);
+        float rtLum = max(dot(color.rgb, luma), 0.02);
+        float lumRatio = clamp(rtLum / baseLum, 0.72, 1.32);
+        float3 chromaRatio = clamp(rawRatio, float3(0.78, 0.78, 0.78), float3(1.28, 1.28, 1.28));
+        float3 smoothRatio = lerp(float3(lumRatio, lumRatio, lumRatio), chromaRatio, 0.20);
 
-        // Clamp the multiplier so a single low-res RT sample cannot create huge
-        // block-to-block brightness jumps or colored squares.
-        lightRatio = clamp(lightRatio, float3(0.45, 0.45, 0.45), float3(1.85, 1.85, 1.85));
+        float invBlockW = 1.0 / max((float)(x1 - x0), 1.0);
+        float invBlockH = 1.0 / max((float)(y1 - y0), 1.0);
 
         [loop]
         for (uint y = y0; y < y1; ++y)
@@ -2407,11 +2414,22 @@ void StoreRaytracedOutput(uint2 dispatchPixel, float4 color)
             for (uint x = x0; x < x1; ++x)
             {
                 float4 pxBase = gAlbedoTex.Load(int3(uint2(x, y), 0));
-                float3 detailPreserved = pxBase.rgb * lightRatio;
 
-                // Keep most of the original per-pixel color detail. The RT result
-                // contributes the lighting/shadow term, not a blocky replacement image.
-                float3 outColor = lerp(color.rgb, detailPreserved, 0.88);
+                float2 blockUv = (float2((float)(x - x0), (float)(y - y0)) + 0.5) * float2(invBlockW, invBlockH);
+                float edgeX = min(blockUv.x, 1.0 - blockUv.x);
+                float edgeY = min(blockUv.y, 1.0 - blockUv.y);
+                float edgeFade = saturate(min(edgeX, edgeY) * 3.5);
+                edgeFade = edgeFade * edgeFade * (3.0 - 2.0 * edgeFade);
+
+                // Strongest RT contribution near the center of each low-res cell,
+                // softer at borders so adjacent cells do not form visible squares.
+                float rtStrength = lerp(0.22, 0.68, edgeFade);
+                float3 finalRatio = lerp(float3(1.0, 1.0, 1.0), smoothRatio, rtStrength);
+                float3 outColor = pxBase.rgb * finalRatio;
+
+                // Avoid crushed black blocks in dark areas, but still allow contact
+                // shadows to slightly darken corners and occluded surfaces.
+                outColor = max(outColor, pxBase.rgb * 0.60);
                 gOutputTex[uint2(x, y)] = float4(outColor, pxBase.a);
             }
         }
