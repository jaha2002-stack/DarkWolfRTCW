+		m.albedo[0] = 0.62f + 0.18f * detailHint;
+		m.albedo[1] = 0.58f + 0.14f * detailHint;
+		m.albedo[2] = 0.50f + 0.10f * detailHint;
+		m.albedo[3] = 1.0f;
