+		glRaytracingMaterial_t m = {};
+		const float dynamicHint = mesh.descCpu.allowUpdate ? 1.0f : 0.0f;
+		const float triCount = (float)(mesh.indicesCpu.size() / 3);
+		const float detailHint = glRaytracingClamp<float>(triCount / 256.0f, 0.0f, 1.0f);
