+float3 DXR_Denoise3x3(uint2 pixel, float3 current, uint screenW, uint screenH)
+{
+    float3 acc = current * 4.0;
+    float w = 4.0;
+    [unroll]
+    for (int oy = -1; oy <= 1; ++oy)
+    {
+        [unroll]
+        for (int ox = -1; ox <= 1; ++ox)
+        {
+            if (ox == 0 && oy == 0) continue;
+            int2 p = int2(pixel) + int2(ox, oy);
+            p.x = clamp(p.x, 0, (int)screenW - 1);
+            p.y = clamp(p.y, 0, (int)screenH - 1);
+            float3 n = gAlbedoTex.Load(int3(p, 0)).rgb;
+            float lumDelta = abs(dot(n - current, float3(0.299, 0.587, 0.114)));
+            float nw = saturate(1.0 - lumDelta * 3.5);
+            acc += n * nw;
+            w += nw;
+        }
+    }
+    return acc / max(w, 1e-3);
+}
