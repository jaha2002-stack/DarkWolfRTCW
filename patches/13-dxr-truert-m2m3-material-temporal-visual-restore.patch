+RTMaterial LoadMaterial(uint materialId)
+{
+    RTMaterial m;
+    m.albedo = float4(0.78, 0.74, 0.66, 1.0);
+    m.material = float4(0.32, 0.0, 0.75, 0.0);
+
+    if (gMaterialCount > 0u)
+    {
+        uint idx = min(materialId, gMaterialCount - 1u);
+        m = gMaterials[idx];
+    }
+
+    m.albedo.rgb = max(m.albedo.rgb, float3(0.02, 0.02, 0.02));
+    m.material.x = saturate(m.material.x);
+    m.material.y = saturate(m.material.y);
+    m.material.z = saturate(m.material.z);
+    m.material.w = max(m.material.w, 0.0);
+    return m;
+}
+
+[shader("closesthit")]
+void RadianceClosestHit(inout RadiancePayload payload, in BuiltInTriangleIntersectionAttributes attr)
+{
+    uint id = InstanceID();
+    RTMaterial m = LoadMaterial(id);
+    payload.hit = 1u;
+    payload.materialId = id;
+    payload.hitT = RayTCurrent();
+
+    float facing = saturate(abs(dot(WorldRayDirection(), -WorldRayDirection())));
+    float specHint = lerp(0.35, 1.0, m.material.z);
+    payload.color = m.albedo.rgb * (0.32 + 0.30 * specHint + 0.10 * facing) + m.material.w;
+}
