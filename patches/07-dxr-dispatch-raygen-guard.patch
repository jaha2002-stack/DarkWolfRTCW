 	DebugBreak();
 }
 
+static bool QD3D12_IsDeviceRemovedLike(HRESULT hr)
+{
+	return hr == DXGI_ERROR_DEVICE_REMOVED ||
+		hr == DXGI_ERROR_DEVICE_RESET ||
+		hr == DXGI_ERROR_DEVICE_HUNG;
+}
+
+static bool QD3D12_ShouldSuppressAfterDXRDeviceLost(HRESULT hr, const char* what, const char* file, int line)
+{
+	if (!QD3D12_IsDeviceRemovedLike(hr))
+		return false;
+
+	if (!glRaytracingHandleExternalD3D12Failure(hr, what, file, line))
+		return false;
+
+	char buffer[1024];
+	_snprintf_s(buffer, sizeof(buffer), _TRUNCATE,
+		"QD3D12 SOFT: suppressing fatal after DXR device lost: %s failed 0x%08X at %s:%d\n",
+		what ? what : "D3D12 call", (unsigned)hr, file ? file : "?", line);
+	OutputDebugStringA(buffer);
+	return true;
+}
