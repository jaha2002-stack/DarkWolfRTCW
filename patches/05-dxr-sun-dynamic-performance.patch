--- a/src/renderer/tr_cmesh.cpp
+++ b/src/renderer/tr_cmesh.cpp
@@ -326,9 +326,18 @@ void R_AddMDCSurfaces( trRefEntity_t *ent ) {
 		 || ( ent->e.frame < 0 )
 		 || ( ent->e.oldframe >= tr.currentModel->mdc[0]->numFrames )
 		 || ( ent->e.oldframe < 0 ) ) {
-		ri.Printf( PRINT_DEVELOPER, "R_AddMDCSurfaces: no such frame %d to %d for '%s'\n",
+		static int s_mdcFrameWarningCount = 0;
+		if (s_mdcFrameWarningCount < 16)
+		{
+			ri.Printf( PRINT_DEVELOPER, "R_AddMDCSurfaces: no such frame %d to %d for '%s'\n",
 				   ent->e.oldframe, ent->e.frame,
 				   tr.currentModel->name );
+		}
+		else if (s_mdcFrameWarningCount == 16)
+		{
+			ri.Printf( PRINT_DEVELOPER, "R_AddMDCSurfaces: suppressing repeated bad-frame warnings\n" );
+		}
+		++s_mdcFrameWarningCount;
 		ent->e.frame = 0;
 		ent->e.oldframe = 0;
 	}
