+static void RB_ApplyDXRPerformanceSettings(void)
+{
+	int preset = r_dxrPerfPreset ? r_dxrPerfPreset->integer : 1;
+	int maxLights = r_dxrMaxLights ? r_dxrMaxLights->integer : 8;
+	int shadowSamples = r_dxrShadowSamples ? r_dxrShadowSamples->integer : 2;
+	int aoSamples = r_dxrAOSamples ? r_dxrAOSamples->integer : 0;
+	int skySamples = r_dxrSkySamples ? r_dxrSkySamples->integer : 1;
+
+	if (preset < 0)
+		preset = 0;
+	if (preset > 4)
+		preset = 4;
+
+	switch (preset)
+	{
+	case 1: // Low / playable: biggest FPS win.
+		maxLights = 6;
+		shadowSamples = 1;
+		aoSamples = 0;
+		skySamples = 0;
+		break;
+	case 2: // Balanced.
+		maxLights = 10;
+		shadowSamples = 2;
+		aoSamples = 0;
+		skySamples = 1;
+		break;
+	case 3: // High.
+		maxLights = 18;
+		shadowSamples = 3;
+		aoSamples = 1;
+		skySamples = 2;
+		break;
+	case 4: // Cinematic / screenshots.
+		maxLights = 32;
+		shadowSamples = 6;
+		aoSamples = 4;
+		skySamples = 3;
+		break;
+	case 0:
+	default:
+		break;
+	}
+
+	if (maxLights < 0) maxLights = 0;
+	if (maxLights > 128) maxLights = 128;
+	if (shadowSamples < 1) shadowSamples = 1;
+	if (shadowSamples > 12) shadowSamples = 12;
+	if (aoSamples < 0) aoSamples = 0;
+	if (aoSamples > 24) aoSamples = 24;
+	if (skySamples < 0) skySamples = 0;
+	if (skySamples > 8) skySamples = 8;
+
+	glRaytracingLightingSetPerformance(
+		(uint32_t)maxLights,
+		(uint32_t)shadowSamples,
+		(uint32_t)aoSamples,
+		(uint32_t)skySamples,
+		r_dxrSync ? r_dxrSync->integer : 0);
+}
+
+static void RB_ApplyDXRSunSettings(void)
+{
+	int enabled = r_dxrSunEnable ? r_dxrSunEnable->integer : 0;
+	float intensity = r_dxrSunIntensity ? r_dxrSunIntensity->value : 0.65f;
+	float pitch = r_dxrSunPitch ? r_dxrSunPitch->value : 42.0f;
+	float yaw = r_dxrSunYaw ? r_dxrSunYaw->value : 135.0f;
+	float shadowStrength = r_dxrSunShadowStrength ? r_dxrSunShadowStrength->value : 0.65f;
+	float sr = 1.0f, sg = 0.92f, sb = 0.78f;
+
+	if (r_dxrSunColor && r_dxrSunColor->string)
+	{
+		sscanf(r_dxrSunColor->string, "%f %f %f", &sr, &sg, &sb);
+	}
+
+	float pr = DEG2RAD(pitch);
+	float yr = DEG2RAD(yaw);
+	float cp = cosf(pr);
+	float dirX = cosf(yr) * cp;
+	float dirY = sinf(yr) * cp;
+	float dirZ = sinf(pr);
+
+	glRaytracingLightingSetSun(
+		enabled,
+		dirX, dirY, dirZ,
+		sr, sg, sb,
+		intensity,
+		shadowStrength);
+}
