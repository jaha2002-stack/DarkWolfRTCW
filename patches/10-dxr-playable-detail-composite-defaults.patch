--- a/src/opengl/gl_d3d12raylight.cpp	2026-07-12 08:31:29.227671624 +0000
+++ b/src/opengl/gl_d3d12raylight.cpp	2026-07-12 08:57:23.626439417 +0000
@@ -2381,6 +2381,43 @@
     x1 = min(max(x1, x0 + 1u), screenW);
     y1 = min(max(y1, y0 + 1u), screenH);
 
+    // Playable TDR-safe composite:
+    // The old low-resolution path wrote one full shaded color to each output block.
+    // That was stable, but visibly pixelated the entire image into large squares.
+    // For full lighting mode, preserve full-resolution raster texture detail and only
+    // reuse the low-resolution RT lighting multiplier. This keeps RT shadows/light
+    // cheap while avoiding chunky texture blocks. Diagnostic modes keep their raw
+    // colors so tests remain easy to identify.
+    if (gRaygenMode == 4u)
+    {
+        uint sx = ((dispatchPixel.x * 2u + 1u) * screenW) / (dispatchW * 2u);
+        uint sy = ((dispatchPixel.y * 2u + 1u) * screenH) / (dispatchH * 2u);
+        uint2 samplePixel = uint2(min(sx, screenW - 1u), min(sy, screenH - 1u));
+        float3 sampleBase = max(gAlbedoTex.Load(int3(samplePixel, 0)).rgb, float3(0.08, 0.08, 0.08));
+        float3 lightRatio = color.rgb / sampleBase;
+
+        // Clamp the multiplier so a single low-res RT sample cannot create huge
+        // block-to-block brightness jumps or colored squares.
+        lightRatio = clamp(lightRatio, float3(0.45, 0.45, 0.45), float3(1.85, 1.85, 1.85));
+
+        [loop]
+        for (uint y = y0; y < y1; ++y)
+        {
+            [loop]
+            for (uint x = x0; x < x1; ++x)
+            {
+                float4 pxBase = gAlbedoTex.Load(int3(uint2(x, y), 0));
+                float3 detailPreserved = pxBase.rgb * lightRatio;
+
+                // Keep most of the original per-pixel color detail. The RT result
+                // contributes the lighting/shadow term, not a blocky replacement image.
+                float3 outColor = lerp(color.rgb, detailPreserved, 0.88);
+                gOutputTex[uint2(x, y)] = float4(outColor, pxBase.a);
+            }
+        }
+        return;
+    }
+
     [loop]
     for (uint y = y0; y < y1; ++y)
     {
