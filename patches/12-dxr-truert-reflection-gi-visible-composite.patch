+float3 ComputeTrueRTReflectionGI(float3 worldPos, float3 N, float3 V, float3 baseAlbedo, uint2 pixel, float skyVis)
+{
+    // DXR TRUE RT M1:
+    // This is the first real ray-traced reflection/GI step.  It still uses the
+    // existing shadow hit group for stability, but it traces a real reflection
+    // ray through the TLAS and converts the result into a conservative glossy
+    // indirect/specular contribution.  Later milestones can replace this with
+    // a full material closest-hit shader and texture table.
+    float NdotV = saturate(dot(N, V));
+    float3 R = normalize(reflect(-V, N));
+
+    float roughMetalHint = saturate((max(max(baseAlbedo.r, baseAlbedo.g), baseAlbedo.b) - 0.70) * 1.65);
+    float fresnel = pow(1.0 - NdotV, 5.0);
+    float reflectStrength = saturate(0.035 + fresnel * 0.45 + roughMetalHint * 0.16);
+
+    float3 rayOrigin = worldPos + N * (gShadowBias * 2.5) + R * (gShadowBias * 2.0);
+    float missVisibility = TraceShadow(rayOrigin, R, 8192.0);
+
+    float upness = saturate(R.z * 0.5 + 0.5);
+    float3 skyCol = lerp(float3(0.18, 0.20, 0.24), float3(0.58, 0.62, 0.70), upness);
+    float3 hitCol = baseAlbedo * 0.18;
+    float3 reflCol = lerp(hitCol, skyCol * max(skyVis, 0.35), missVisibility);
+
+    // Tiny blue-noise-like dither hides low-res RT cell boundaries without
+    // changing the underlying full-resolution raster texture detail.
+    float d = Hash12((float2)pixel + worldPos.xy * 0.017 + worldPos.zz * 0.031) - 0.5;
+    reflectStrength *= 1.0 + d * 0.12;
+
+    return reflCol * reflectStrength;
+}
