+void StoreRaytracedOutput(uint2 dispatchPixel, float4 color)
+{
+    uint screenW = max((uint)gScreenSize.x, 1u);
+    uint screenH = max((uint)gScreenSize.y, 1u);
+    uint dispatchW = max(gDispatchWidth, 1u);
+    uint dispatchH = max(gDispatchHeight, 1u);
+
+    if (gCompositeBlocks == 0u || (dispatchW >= screenW && dispatchH >= screenH))
+    {
+        if (dispatchPixel.x < screenW && dispatchPixel.y < screenH)
+            gOutputTex[dispatchPixel] = color;
+        return;
+    }
+
+    uint x0 = (dispatchPixel.x * screenW) / dispatchW;
+    uint y0 = (dispatchPixel.y * screenH) / dispatchH;
+    uint x1 = ((dispatchPixel.x + 1u) * screenW + dispatchW - 1u) / dispatchW;
+    uint y1 = ((dispatchPixel.y + 1u) * screenH + dispatchH - 1u) / dispatchH;
+
+    x0 = min(x0, screenW - 1u);
+    y0 = min(y0, screenH - 1u);
+    x1 = min(max(x1, x0 + 1u), screenW);
+    y1 = min(max(y1, y0 + 1u), screenH);
+
+    [loop]
+    for (uint y = y0; y < y1; ++y)
+    {
+        [loop]
+        for (uint x = x0; x < x1; ++x)
+        {
+            gOutputTex[uint2(x, y)] = color;
+        }
+    }
